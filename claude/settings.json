{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "allow": [
      "mcp__linear-server__get_issue"
    ]
  },
  "hooks": {
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "claude-tab-notify"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "claude-tab-notify"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "swift-lsp@claude-plugins-official": false,
    "rust-analyzer-lsp@claude-plugins-official": false
  },
  "statusLine": {
    "type": "command",
    "command": "command -v bud >/dev/null && bud statusline"
  },
  "effortLevel": "high",
  "voiceEnabled": false,
  "skipDangerousModePermissionPrompt": true,
  "attribution": {
    "commit": ""
  }
}
