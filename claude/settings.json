{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "DISABLE_AUTOUPDATER": "1"
  },
  "attribution": {
    "commit": ""
  },
  "permissions": {
    "allow": [
      "mcp__linear-server__get_issue"
    ]
  },
  "hooks": {
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "claude-tab-notify"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "claude-tab-notify"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/herdr-agent-state.sh\" session",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "claude-tab-notify"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "claude-tab-notify"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "command -v bud >/dev/null && bud statusline"
  },
  "enabledPlugins": {
    "figma@claude-plugins-official": true,
    "rust-analyzer-lsp@claude-plugins-official": false,
    "swift-lsp@claude-plugins-official": false
  },
  "effortLevel": "xhigh",
  "tui": "fullscreen",
  "skipDangerousModePermissionPrompt": true,
  "remoteControlAtStartup": true,
  "agentPushNotifEnabled": true,
  "voiceEnabled": false
}
