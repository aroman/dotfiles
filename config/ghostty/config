# Font
font-family = CaskaydiaCove Nerd Font Mono
font-size = 16
font-thicken = false

# Inner padding
window-padding-x = 2

# Use P3 color space to match iTerm2
window-colorspace = display-p3

# Theme — swap between: "OneDark Custom", "Everblush", "TokyoNight"
theme = Everblush

# Cursor
cursor-style = bar
cursor-style-blink = true
adjust-cursor-thickness = 4

# Window
macos-titlebar-style = transparent
macos-window-buttons = hidden
macos-icon = chalkboard
# macos-icon-ghost-color = #ffffff
# macos-icon-screen-color = #bb7cd7
# macos-icon-frame=beige
macos-option-as-alt = true
macos-titlebar-proxy-icon = hidden

# Splits
unfocused-split-opacity = 1
split-divider-color = #38393E

# Terminal
term = xterm-256color

# Behavior
mouse-hide-while-typing = true
mouse-scroll-multiplier = precision:2
link-url = true
link-previews = true

# Quick terminal (like iTerm2 Ctrl+` hotkey window)
keybind = global:ctrl+grave_accent=toggle_quick_terminal

# Cmd+Delete sends Ctrl+U (kill line, matches iTerm2)
keybind = super+backspace=text:\x15

# Bell: emoji in tab title + dock bounce
bell-features = title,attention

# Notify when long-running commands finish in unfocused tabs
notify-on-command-finish = never
