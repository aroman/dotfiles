# Font
font-family = Cascadia Code
font-size = 13
font-variation = wght=450
font-thicken = false

# Inner padding
window-padding-x = 4

# Use P3 color space to match iTerm2
window-colorspace = display-p3

# Theme — swap between: "OneDark Custom", "Everblush", "TokyoNight"
theme = Everblush

# Cursor
cursor-style = bar
cursor-style-blink = false
adjust-cursor-thickness = 4

# Splits
unfocused-split-opacity = 1
split-divider-color = #38393E

# Behavior
mouse-hide-while-typing = true
mouse-scroll-multiplier = precision:2
link-url = true
link-previews = true

# Bell
bell-features = title,attention,border,audio

# Notify when long-running commands finish in unfocused tabs
notify-on-command-finish = never

# Undo close tab: extend recovery window from 5s default
undo-timeout = 30s

# OS-specific overrides (silently ignored if file doesn't exist).
# Each OS only gets its own file in ~/.config/ghostty/:
#   macOS → rcm symlinks it (and `linux` is in rcrc EXCLUDES)
#   Linux → home-manager symlinks it (and `macos` is omitted there)
config-file = ?macos
config-file = ?linux
