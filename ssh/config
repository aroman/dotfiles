IgnoreUnknown UseKeychain

# Machine-specific keys and hosts (not tracked in dotfiles).
# IMPORTANT: this must come before any Match block — Match swallows
# everything after it until the next Host/Match keyword.
Include ~/.ssh/config.local

Match host * exec "test -f ~/.orbstack/ssh/config"
  Include ~/.orbstack/ssh/config

Host *
  SendEnv COLORTERM

Host moonbinder moonbinder.marlin-antares.ts.net dawnbinder dawnbinder.marlin-antares.ts.net wizardtower wizardtower.marlin-antares.ts.net dad dad.tail5c0d6f.ts.net
  ControlMaster auto
  ControlPath ~/.ssh/cm-%r@%h:%p
  ControlPersist 10m

# HostName uses the raw Tailscale IP instead of the MagicDNS FQDN because
# tailscaled's split-DNS-via-systemd-resolved mode pushes a public anycast
# resolver (199.247.155.53) that only answers for the ts.net root + Funnel
# devices — regular MagicDNS lookups return NXDOMAIN. Hardcoding the 100.x
# IPs sidesteps DNS entirely. IPs are sticky per registered node.
# See https://github.com/tailscale/tailscale/issues/16558
# Agent-forwarding policy: every machine in this file is one we own and trust,
# and each carries its own SSH key (see the "machine-specific key" setup in
# README.md) used via its local ssh-agent (programs.ssh.startAgent + linger).
# We deliberately do NOT ForwardAgent between them. Forwarding exists to borrow
# a key onto a host you don't want to store one on — the opposite of our case,
# so it buys nothing here. It also widens attack surface and, worse, pins
# SSH_AUTH_SOCK to a per-connection socket that goes stale inside long-lived
# tmux panes, silently breaking commit signing in reattached sessions. For a
# genuine onward hop using this machine's identity, prefer ProxyJump (-J).
Host moonbinder moonbinder.marlin-antares.ts.net
  HostName 100.106.254.15
  SendEnv GHOSTTY_RESOURCES_DIR

Host dawnbinder dawnbinder.marlin-antares.ts.net
  HostName 100.76.66.127
  SendEnv GHOSTTY_RESOURCES_DIR

Host wizardtower wizardtower.marlin-antares.ts.net
  HostName 100.116.179.31
  SendEnv GHOSTTY_RESOURCES_DIR

Host dad dad.tail5c0d6f.ts.net
  HostName 100.71.243.105
  SendEnv GHOSTTY_RESOURCES_DIR

# Forward the opener(1) socket so xdg-open on the remote opens URLs in the
# local browser via opener.  The `exec` test only matches when the socket
# exists locally (i.e., when the client is the Mac running `brew services
# start superbrothers/opener/opener`); Linux→Linux SSH skips this cleanly.
Match host moonbinder*,dawnbinder*,wizardtower* exec "test -S ~/.opener.sock"
  RemoteForward /home/aroman/.opener.sock %d/.opener.sock

Host github.com
  # Route through port 443 so SSH works on networks that block port 22
  Hostname ssh.github.com
  Port 443
  AddKeysToAgent yes
  UseKeychain yes
