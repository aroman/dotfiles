#!/usr/bin/env bash
set -euo pipefail

# Swap content workspaces between the focused (mouse) monitor and the other
# monitor. No-op if the other monitor has no real workspaces to give, so we
# don't shove your stuff onto an empty display. Focus ends up on the mouse
# monitor, showing the workspace that just arrived. Assumes two monitors.

if [ -z "${NIRI_SOCKET:-}" ]; then
    echo "Not running inside a niri session." >&2
    exit 1
fi

niri msg --json workspaces | jq -c '
    # A workspace is worth moving if it has windows or is user-named.
    # Filters out niris auto-placeholder trailing empties AND any other
    # unnamed empty (e.g. a mid-stack one awaiting cleanup, or the
    # trailing empty while it happens to be active) so they cannot
    # sneak into $pull and become a misleading focus target.
    def is_movable: .active_window_id != null or .name != null;

    ([ .[] | select(.is_focused) ][0].output)    as $fo |
    ([ .[] | select(.output != $fo) ][0].output) as $oo |
    ([ .[] | select(.output == $fo and is_movable) ] | sort_by(.idx)) as $push |
    ([ .[] | select(.output == $oo and is_movable) ] | sort_by(.idx)) as $pull |

    if $oo == null or ($pull | length) == 0 then empty
    else
      # Prefer the workspace that was active on the other monitor; fall
      # back to the first movable one if the active one was an empty we
      # just filtered out. Either way, always emit a FocusWorkspace —
      # otherwise niri would silently follow our pushed workspaces to $oo.
      (([ $pull[] | select(.is_active) ][0]) // $pull[0]).id as $target |
      ( [ $push[] | {"Action":{"MoveWorkspaceToMonitor":{"output":$oo,"reference":{"Id":.id}}}} ]
      + [ $pull[] | {"Action":{"MoveWorkspaceToMonitor":{"output":$fo,"reference":{"Id":.id}}}} ]
      + [{"Action":{"FocusWorkspace":{"reference":{"Id":$target}}}}]
      )[]
    end
' | socat - UNIX-CONNECT:"$NIRI_SOCKET" > /dev/null
