#!/usr/bin/env sh
# Disables touchpad-while-typing (dwt) when Figma is focused,
# re-enables it otherwise. Relies on niri's config hot-reload.

CONFIG="$HOME/.config/niri/config.kdl"
in_figma=false

enable_dwt() {
    sed -i 's|^\(\s*\)// dwt$|\1dwt|' "$CONFIG"
}

disable_dwt() {
    sed -i 's|^\(\s*\)dwt$|\1// dwt|' "$CONFIG"
}

trap enable_dwt EXIT
enable_dwt

niri msg -j event-stream \
  | jq --unbuffered -c 'select(.WindowFocusTimestampChanged)' \
  | while read -r _; do
      app_id=$(niri msg -j focused-window 2>/dev/null | jq -r '.app_id // ""')
      case "$app_id" in
          figma-linux|chrome-www.figma.com*)
              if [ "$in_figma" = false ]; then
                  in_figma=true
                  disable_dwt
              fi
              ;;
          *)
              if [ "$in_figma" = true ]; then
                  in_figma=false
                  enable_dwt
              fi
              ;;
      esac
    done
