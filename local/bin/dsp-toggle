#!/usr/bin/env bash
set -euo pipefail

# A/B toggle between DSP-processed and raw output on the internal speakers.
# wireplumber refuses to route streams into the hidden raw sink
# (Audio/Sink/Internal), so we re-link them directly with pw-link.

DSP_SINK="effect_input.fw16_speaker_dsp"
RAW_SINK="fw16_speakers_internal"
DSP_OUTPUT="effect_output.fw16_speaker_dsp"

# Emit "<source_port> <sink_port>" for every user-stream link feeding $1.
# The DSP filter chain's own output is excluded (it's a permanent link).
user_links_into() {
  local target=$1
  pw-link -l | awk -v target="$target" -v skip="$DSP_OUTPUT" '
    /^[^ ]/ { sink = $1; next }
    /\|<-/ && index(sink, target ":") == 1 && index($2, skip ":") != 1 {
      print $2, sink
    }
  '
}

# Move all user-stream links from $1 sink to $2 sink. Echo unique stream count.
swap_links() {
  local from=$1 to=$2
  local -A streams=()
  while read -r src sink; do
    pw-link -d "$src" "$sink" 2>/dev/null || true
    pw-link "$src" "${sink/#$from:/$to:}" 2>/dev/null || true
    streams[${src%%:*}]=1
  done < <(user_links_into "$from")
  echo "${#streams[@]}"
}

bold="" dim="" reset=""
if [ -t 1 ]; then
  bold=$(tput bold 2>/dev/null || true)
  dim=$(tput dim 2>/dev/null || true)
  reset=$(tput sgr0 2>/dev/null || true)
fi

# Derive current state from the graph: any user stream feeding raw → "off".
if [ -n "$(user_links_into "$RAW_SINK")" ]; then
  from=$RAW_SINK to=$DSP_SINK label="on " dest="filter chain"
else
  from=$DSP_SINK to=$RAW_SINK label="off" dest="raw speakers"
fi

n=$(swap_links "$from" "$to")
if [ "$n" -eq 0 ]; then
  printf '%sno active audio streams to toggle%s\n' "$dim" "$reset"
else
  printf '%sDSP %s%s %s· %s stream(s) → %s%s\n' \
    "$bold" "$label" "$reset" "$dim" "$n" "$dest" "$reset"
fi
