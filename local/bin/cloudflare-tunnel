#!/usr/bin/env bash
set -uo pipefail

METRICS_ADDR="127.0.0.1:20241"
PIDFILE="${XDG_RUNTIME_DIR:-${TMPDIR:-/tmp}}/cloudflare-tunnel.pid"
# The tunnel token is a static credential. Keep it in a 0600 file outside the
# dotfiles repo so this works identically on the desktop and over SSH, with no
# password-manager / GUI dependency. Populate it once with:
#   install -m600 /dev/stdin ~/.config/cloudflare-tunnel/token   (paste, ^D)
TOKEN_FILE="${XDG_CONFIG_HOME:-$HOME/.config}/cloudflare-tunnel/token"

is_running() {
  [[ -f "$PIDFILE" ]] && kill -0 "$(cat "$PIDFILE")" 2>/dev/null
}

case "${1:-start}" in
  start)
    if is_running; then
      exit 0
    fi

    if [[ ! -s "$TOKEN_FILE" ]]; then
      echo "cloudflare-tunnel: no token at $TOKEN_FILE." \
           "Create it (mode 0600) with the tunnel token from the Cloudflare" \
           "Zero Trust dashboard." >&2
      exit 1
    fi
    token=$(cat "$TOKEN_FILE")

    LOGFILE="${XDG_RUNTIME_DIR:-${TMPDIR:-/tmp}}/cloudflare-tunnel.log"
    TUNNEL_TOKEN="$token" nohup cloudflared tunnel --metrics "$METRICS_ADDR" run \
      </dev/null >>"$LOGFILE" 2>&1 &
    echo $! > "$PIDFILE"
    disown
    ;;
  stop)
    if is_running; then
      kill "$(cat "$PIDFILE")" 2>/dev/null
      rm -f "$PIDFILE"
      echo "Tunnel stopped."
    else
      rm -f "$PIDFILE"
      echo "Tunnel is not running."
    fi
    ;;
  status)
    if ! is_running; then
      echo "disconnected"
    elif curl -sf --connect-timeout 0.5 --max-time 1 "http://$METRICS_ADDR/ready" >/dev/null 2>&1; then
      echo "connected"
    else
      echo "starting"
    fi
    ;;
  *)
    echo "Usage: cloudflare-tunnel [start|stop|status]"
    exit 1
    ;;
esac
