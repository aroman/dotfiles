#!/usr/bin/env bash
set -uo pipefail

UNIT_NAME="cloudflare-tunnel"
METRICS_ADDR="127.0.0.1:20241"

case "${1:-start}" in
  start)
    if systemctl --user is-active --quiet "$UNIT_NAME" 2>/dev/null; then
      exit 0
    fi

    token=$(op read "op://Private/Cloudflare Tunnel - avi.magiccircle.dev/token") || exit 1

    systemd-run --user \
      --unit="$UNIT_NAME" \
      --description="Cloudflare Tunnel" \
      --property=Restart=on-failure \
      --property=RestartSec=5 \
      --setenv="TUNNEL_TOKEN=$token" \
      -- cloudflared tunnel --metrics "$METRICS_ADDR" run
    ;;
  stop)
    systemctl --user stop "$UNIT_NAME" 2>/dev/null && echo "Tunnel stopped." || echo "Tunnel is not running."
    ;;
  status)
    if curl -sf --max-time 2 "http://$METRICS_ADDR/ready" >/dev/null 2>&1; then
      echo "connected"
    elif systemctl --user is-active --quiet "$UNIT_NAME" 2>/dev/null; then
      echo "starting"
    else
      echo "disconnected"
    fi
    ;;
  *)
    echo "Usage: cloudflare-tunnel [start|stop|status]"
    exit 1
    ;;
esac
