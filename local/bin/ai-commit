#!/usr/bin/env bash
set -euo pipefail

GEMINI_MODEL="gemini-3.1-flash-lite-preview"
GEMINI_API_KEY="${GEMINI_API_KEY:-}"

if [ -z "$GEMINI_API_KEY" ]; then
  echo "GEMINI_API_KEY not set." >&2
  exit 1
fi

tmpfile=$(mktemp)
cleanup() { rm -f "$tmpfile"; tput cnorm 2>/dev/null; }
trap cleanup EXIT
trap 'cleanup; exit 130' INT TERM

diff=$(git diff --cached)
if [ -z "$diff" ]; then
  echo "No staged changes."
  echo ""
  git -c color.status=always status --short
  echo ""
  if [ -z "$(git status --porcelain)" ]; then
    echo "Nothing to commit." >&2
    exit 1
  fi
  printf "Stage all changes? [Y/n] "
  read -r answer
  if [[ ! "$answer" =~ ^[Nn]$ ]]; then
    git add -A
    diff=$(git diff --cached)
  else
    exit 1
  fi
fi

context=$(
  echo "=== Recent commits (for style reference) ==="
  git log --oneline -10 2>/dev/null || true
  echo ""
  echo "=== Changed files ==="
  git diff --cached --stat
  echo ""
  echo "=== Diff ==="
  echo "$diff" | head -c 15000
)

spin() {
  local chars="⠋⠙⠹⠸⠼⠴⠦⠧⠇⠏"
  local pid=$1
  local i=0
  tput civis 2>/dev/null || true
  while kill -0 "$pid" 2>/dev/null; do
    printf "\r  %s Generating commit message..." "${chars:i%${#chars}:1}"
    i=$((i + 1))
    sleep 0.08
  done
  printf "\r\033[K"
  tput cnorm 2>/dev/null || true
}

SYSTEM_PROMPT='You generate concise git commit messages from diffs.

Rules:
- Use Conventional Commits format: type(scope): description
- Types: feat, fix, docs, style, refactor, perf, test, build, ci, chore
- Scope is optional, use when it adds clarity (e.g. a module or component name)
- Description: imperative mood, lowercase, no period
- Keep under 72 characters
- Match the style of the recent commits shown, if any
- Output ONLY the commit message — no quotes, no explanation, no markdown'

body=$(jq -n --arg sys "$SYSTEM_PROMPT" --arg input "$context" '{
  system_instruction: {parts: [{text: $sys}]},
  contents: [{parts: [{text: $input}]}]
}')

curl -sf "https://generativelanguage.googleapis.com/v1beta/models/${GEMINI_MODEL}:generateContent?key=${GEMINI_API_KEY}" \
  -H 'Content-Type: application/json' \
  -d "$body" > "$tmpfile" 2>&1 &
pid=$!
spin $pid
wait $pid || true

msg=$(jq -r '.candidates[0].content.parts[0].text // empty' "$tmpfile" 2>/dev/null)

if [ -z "$msg" ]; then
  echo "Failed to generate message." >&2
  cat "$tmpfile" >&2
  exit 1
fi

git commit -e -m "$msg"
