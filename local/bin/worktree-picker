#!/usr/bin/env bash
#
# worktree-picker — graphical worktree picker for magiccircle.gg
#
# Lists git worktrees in fuzzel (Wayland dmenu), opens the selected one
# in Zed. Bound to Mod+I in niri config.
#
# Dependencies: git, fuzzel, zeditor (Zed), niri, notify-send
#
set -euo pipefail

MAIN_REPO="$HOME/Projects/magiccircle.gg"

# --- Parse worktrees ---
# Uses `git worktree list --porcelain` which outputs blocks like:
#   worktree /path/to/worktree
#   HEAD <sha>
#   branch refs/heads/<branch>
#   <blank line>
# We skip the main repo (not a worktree branch).
dirs=()
branches=()
current_wt=""

while IFS= read -r line; do
  if [[ "$line" == worktree\ * ]]; then
    current_wt="${line#worktree }"
  elif [[ "$line" == branch\ * ]]; then
    branch="${line#branch refs/heads/}"
    if [[ "$current_wt" != "$MAIN_REPO" ]]; then
      dirs+=("$current_wt")
      branches+=("$branch")
    fi
  elif [[ -z "$line" ]]; then
    current_wt=""
  fi
done < <(git -C "$MAIN_REPO" worktree list --porcelain)

if [[ ${#branches[@]} -eq 0 ]]; then
  notify-send "Worktree Picker" "No active worktrees."
  exit 0
fi

# --- Pick a worktree with fuzzel ---
selected="$(printf '%s\n' "${branches[@]}" \
  | fuzzel --dmenu --prompt "Edit worktree: ")" || exit 0

# --- Open in Zed and maximize ---
for i in "${!branches[@]}"; do
  if [[ "${branches[$i]}" == "$selected" ]]; then
    zeditor --new "${dirs[$i]}" &

    # Zed overrides niri's initial configure request, so the open-maximized
    # window rule doesn't work. Instead we poll for the Zed window to appear
    # and maximize it via niri IPC.
    # https://github.com/niri-wm/niri/wiki/Configuration:-Window-Rules
    # https://github.com/niri-wm/niri/issues/3144
    for _ in $(seq 1 20); do
      if niri msg focused-window 2>/dev/null | grep -q "dev.zed.Zed"; then
        niri msg action maximize-column
        break
      fi
      sleep 0.05
    done
    exit 0
  fi
done

notify-send "Worktree Picker" "Could not find worktree for '$selected'"
exit 1
