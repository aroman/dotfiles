#!/usr/bin/env bash
# Switch between local and remote display modes on wizardtower.
#
# Local mode:  LG monitor (DP-1) on, HDMI dummy off
# Remote mode: LG off, HDMI dummy (HDMI-A-1) on
#
# HDMI mode + scale are pinned in niri (host-wizardtower.kdl) and never
# changed here — Sunshine's KMS capture wedges across streams if HDMI's
# mode changes between sessions, with the bad state living below niri
# (kernel/NVIDIA-DRM) and surviving systemd restart. So this script just
# toggles outputs on/off; clients receive whatever mode niri has pinned.
#
# Usage: toggle-streaming-res [remote|local]
#   remote  — switch to remote mode (HDMI on, DP off).
#   local   — switch back to local (LG) mode.
#   (none)  — toggle between modes.
#
# Bound to Mod+Shift+D in niri config.
# Called by Sunshine prep-cmd/undo-cmd for auto-switching.

set -euo pipefail

HDMI="HDMI-A-1"
DP="DP-1"

# Wait for niri socket (handles boot race where Sunshine starts before niri).
wait_for_niri() {
    local timeout=30 elapsed=0
    while [ $elapsed -lt $timeout ]; do
        local sock
        sock=$(ls /run/user/1000/niri*.sock 2>/dev/null | head -1)
        if [ -n "$sock" ] && niri msg -j outputs >/dev/null 2>&1; then
            export NIRI_SOCKET="$sock"
            return 0
        fi
        sleep 1
        elapsed=$((elapsed + 1))
    done
    echo "toggle-streaming-res: niri socket not found after ${timeout}s" >&2
    return 1
}

wait_for_niri

switch_to_remote() {
    niri msg output "$HDMI" on
    niri msg output "$DP" off
    notify-send "Display" "Remote mode (HDMI dummy)" 2>/dev/null || true
}

switch_to_local() {
    # If LG (DP-1) isn't physically connected, switching would leave the
    # box with no enabled outputs — sunshine then can't find a monitor on
    # the next stream attempt. Bail and leave HDMI on so things stay
    # captureable.
    local dp_status
    dp_status=$(cat /sys/class/drm/card*-${DP}/status 2>/dev/null | head -1)
    if [ "$dp_status" != "connected" ]; then
        notify-send "Display" "$DP disconnected — staying in remote mode" 2>/dev/null || true
        return 0
    fi
    niri msg output "$DP" on
    niri msg output "$HDMI" off
    notify-send "Display" "Local mode (LG)" 2>/dev/null || true
}

hdmi_is_on() {
    niri msg -j outputs | jq -e '
        to_entries[] | select(.value.name == "HDMI-A-1") | .value.current_mode != null
    ' >/dev/null 2>&1
}

case "${1:-}" in
    remote) switch_to_remote ;;
    local)  switch_to_local ;;
    *)
        if hdmi_is_on; then switch_to_local; else switch_to_remote; fi
        ;;
esac
