#!/bin/sh
case "$(uname)" in
  Darwin)
    exec /Applications/TexturePacker.app/Contents/MacOS/TexturePacker "$@"
    ;;
  *)
    case "$*" in
      *--gui*) exec flatpak run com.codeandweb.texturepacker -platform wayland "$@" ;;
      *)       exec flatpak run com.codeandweb.texturepacker "$@" ;;
    esac
    ;;
esac
