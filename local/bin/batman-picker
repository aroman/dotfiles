#!/usr/bin/env bash
#
# batman-picker — graphical worktree picker for magiccircle.gg dev servers
#
# Lists git worktrees in fuzzel (Wayland dmenu), opens a terminal running
# batman (start_tmux_services.sh) in the selected worktree.
# Bound to Mod+U in niri config.
#
# Dependencies: git, fuzzel, niri, notify-send, worktree-list
# See also: worktree-picker (same picker but opens Zed)
#
set -euo pipefail

MAIN_REPO="$HOME/Projects/magiccircle.gg"
BATMAN_SCRIPT="$MAIN_REPO/scripts/start_tmux_services.sh"
KILL_ZOMBIES="$MAIN_REPO/scripts/kill-zombie-servers.sh"

# Read worktrees (including main) sorted by mtime
mapfile -t entries < <(worktree-list --include-main)

if [[ ${#entries[@]} -eq 0 ]]; then
  notify-send "Batman Picker" "No worktrees found."
  exit 0
fi

# Pick a worktree with fuzzel
selected="$(printf '%s\n' "${entries[@]}" | cut -f1 \
  | fuzzel --dmenu --prompt "Start batman in: ")" || exit 0

# Open terminal running batman in the selected worktree
for entry in "${entries[@]}"; do
  branch="${entry%%	*}"
  dir="${entry#*	}"
  if [[ "$branch" == "$selected" ]]; then
    # Kill zombie dev servers on known ports and clean up any previous
    # batman session before starting a new one.
    "$KILL_ZOMBIES" 2>/dev/null || true

    # Runs inside `nix develop` to get the devshell (provides zellij, pnpm, etc.)
    exec xdg-terminal-exec nix develop "$dir" --command bash -c "cd $(printf '%q' "$dir") && exec $(printf '%q' "$BATMAN_SCRIPT")"
  fi
done

notify-send "Batman Picker" "Could not find worktree for '$selected'"
exit 1
