[include]
	path = ~/.gitconfig.local
[user]
	name = Avi Romanoff
	email = avi@magiccircle.studio
	# signingkey set in ~/.gitconfig.local per machine
[push]
	default = simple
[core]
	excludesfile = ~/.gitignore_global
	editor = vim
	pager = less -RFX --mouse
[pull]
	rebase = true
[filter "lfs"]
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
	clean = git-lfs clean -- %f
[init]
	defaultBranch = main
[gpg]
	program = gpg
	format = ssh
[commit]
	gpgsign = true
[alias]
	dlog = -c diff.external=difft log -p --ext-diff
[diff]
	tool = difftastic
	external = difft
[difftool]
	prompt = false
[difftool "difftastic"]
	cmd = difft "$LOCAL" "$REMOTE"
[pager]
	difftool = true
[rerere]
	enabled = true
[maintenance]
	auto = true
	strategy = incremental
